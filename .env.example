# Anthropic API key, used to write the podcast script from the raw headlines.
ANTHROPIC_API_KEY=sk-ant-...

# Path to the Google Cloud service account JSON, used for BOTH
# Text-to-Speech and Drive upload. The target Drive folder (see
# config.yaml drive.folder_id) must be shared with this service
# account's "client_email" as Editor.
GOOGLE_APPLICATION_CREDENTIALS=credentials/service-account.json
