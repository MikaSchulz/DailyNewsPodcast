# Only needed for full-auto mode (`python3 main.py` with no flags), where
# the script writes the podcast text itself via the Anthropic API. Not
# needed for the agent-orchestrated flow (--fetch-topics-only +
# --script-file), where the calling Claude agent writes the text instead.
ANTHROPIC_API_KEY=sk-ant-...

# Path to the Google Cloud service account JSON, used for Text-to-Speech only.
GOOGLE_APPLICATION_CREDENTIALS=credentials/service-account.json

# Path to the OAuth client secret downloaded from Google Cloud Console
# (Desktop app type). Only needed for the one-time interactive login.
GOOGLE_OAUTH_CLIENT_SECRET=credentials/oauth_client_secret.json

# Path where the Drive OAuth token is cached after that first login
# (auto-created, then refreshed automatically — no more browser popups).
GOOGLE_OAUTH_TOKEN=credentials/token.json
